# Required for Google OAuth sign-in
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Required for session security (use a long random string)
SESSION_SECRET=change_this_to_a_random_32_char_string

# Required for AI features (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Finnhub for financial data
FINNHUB_API_KEY=your_finnhub_api_key_here

# Optional: custom database path (defaults to ./data/meridian.db)
# DB_PATH=/opt/render/project/data/meridian.db
